# PostgreSQL
POSTGRES_USER=algotrader
POSTGRES_PASSWORD=algotrader_secret
POSTGRES_DB=algotrading

# Database URLs
DATABASE_URL=postgresql://algotrader:algotrader_secret@postgres:5432/algotrading
REDIS_URL=redis://redis:6379

# Authentication
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_EMAIL=admin@algotrader.local
ADMIN_PASSWORD=Admin@123
ADMIN_FULL_NAME=Platform Administrator

# API Keys (replace with your actual keys)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key
POLYGON_API_KEY=your_polygon_api_key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8002

# Monitoring
GRAFANA_PASSWORD=admin

# Risk Management
MAX_POSITION_SIZE=100000
MAX_DAILY_LOSS=10000
MAX_LEVERAGE=3.0

# Trading
DEFAULT_COMMISSION_RATE=0.001
DEFAULT_SLIPPAGE_RATE=0.0001
